{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fieldnote",
  "version": "0.1.0",
  "identifier": "com.fieldnote.knowledge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fieldnote",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/Users/**", "/private/**", "**"]
      }
    }
  },
  "bundle": { "active": true, "targets": "all" }
}
